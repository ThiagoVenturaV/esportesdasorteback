# ============================================
# Esportes da Sorte — Backend Environment
# Copie para .env e preencha os valores reais
# ============================================

# -- Neon PostgreSQL --
NEON_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# -- Groq AI --
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_CHAT=meta-llama/llama-4-maverick-17b-128e-instruct

# -- BetsAPI --
BETS_API_TOKEN=seu_token_aqui

# -- JWT Auth --
JWT_SECRET=gere_um_segredo_forte_aqui

# -- CORS (separar por vírgula) --
CORS_ORIGINS=https://seudominio.vercel.app,http://localhost:5173

# -- Rate Limiting --
# Formato: "N/period" (ex: 20/minute)
CHAT_RATE_LIMIT=20/minute

# -- Gunicorn (opcional, padrões no gunicorn.conf.py) --
GUNICORN_WORKERS=5
GUNICORN_LOG_LEVEL=info

# -- Edson AI --
EDSON_WEB_FALLBACK_ENABLED=true
CHAT_DB_ONLY_MODE=false

# -- Live Analysis --
LIVE_ANALYSIS_BACKGROUND_REFRESH=true
LIVE_ANALYSIS_REFRESH_SECONDS=60

# -- TTL (cache de análises) --
ANALYSIS_TTL_LIVE_MINUTES=5
ANALYSIS_TTL_UPCOMING_HOURS=24
