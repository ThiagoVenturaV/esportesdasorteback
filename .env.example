# Database
NEON_URL=postgresql://user:password@host/dbname?sslmode=require

# AI Providers
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL_CHAT=gemini-2.0-flash-lite
GEMINI_MODEL_ANALYSIS=gemini-2.0-flash-lite
GROQ_API_KEY=your_groq_key
# Chat model (conversational, temperature=0.7, max_tokens=600)
GROQ_MODEL_CHAT=openai/gpt-oss-120b
# Analysis model (JSON structured, temperature=0.2, max_tokens=900)
GROQ_MODEL=mixtral-8x7b-32768

# BetsAPI (NUNCA commitar o token real)
BETS_API_TOKEN=your_betsapi_token

# JWT Secret (gerar com: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION_HOURS=24

# CORS
CORS_ORIGINS=https://esportesdasorte.vercel.app,http://localhost:5173

# Optional strict mode
EDSON_DB_ONLY_MODE=false
CHAT_DB_ONLY_MODE=false
RAG_DISABLE_WEB_FETCH=false
EDSON_WEB_FALLBACK_ENABLED=true

# Analysis TTL
ANALYSIS_TTL_LIVE_MINUTES=5
ANALYSIS_TTL_UPCOMING_HOURS=24

# Live cache tuning
HOME_LIVE_ANALYSES_LIMIT=8
LIVE_ANALYSIS_REFRESH_SECONDS=60
LIVE_MATCHES_DB_MAX_AGE_SECONDS=120
LIVE_ANALYSIS_BACKGROUND_REFRESH=true

# Cron job settings
PARQUET_DIR=/data/parquet
INGEST_LIMIT_FILES=2
ANALYSIS_CACHE_RETENTION_DAYS=7
