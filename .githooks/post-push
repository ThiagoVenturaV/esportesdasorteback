#!/usr/bin/env sh
# Dispara checklist apos push para manter frequencia de validacao.
if command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File "deploy/post_push_panel.ps1"
elif command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -File "deploy/post_push_panel.ps1"
else
  echo "[post-push-panel] PowerShell nao encontrado. Rode manualmente: deploy/post_push_panel.ps1"
fi
